# Dependencies
node_modules/
.venv/
venv/
*.pyc
__pycache__/

# Environment (dotenvx)
# .env files ARE committed (encrypted)
# .env.keys is NOT (contains private decryption keys)
.env.keys
.env.local

# Next.js
.next/
out/

# Build
dist/
build/
coverage/

# IDE
.vscode/
.idea/

# Local agent/skill installs (pinned by skills-lock.json; reinstall on clone)
.claude/skills/
.claude/settings.local.json
.agents/skills/

# OS
.DS_Store
Thumbs.db

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Uploads
uploads/

# Trace artifacts — leftover dumps from the deleted _tracer.py. Kept
# ignored so any future ad-hoc dump scripts don't accidentally commit
# binary blobs.
local-shared-data/traces/
# Container-owned scratch / probe scripts. local-shared-data/ is bind-
# mounted as /app/shared-data inside the backend container, so root in
# the container creates files as root on the host. Underscore-prefixed
# .py files are scratch (probes, tracers, one-offs) — ignore so they
# can't sneak back into commits. openapi.json (no underscore) stays
# tracked because the FE codegen reads it.
local-shared-data/_*.py
